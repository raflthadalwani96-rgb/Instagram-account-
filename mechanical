import streamlit as st
import google.generativeai as genai

# 1. إعدادات واجهة المستخدم الاحترافية
st.set_page_config(
    page_title="Mechatronics AI Solver",
    page_icon="🤖",
    layout="centered"
)

# 2. إعداد الاتصال بالذكاء الاصطناعي
# ملاحظة: ضع مفتاح الـ API الخاص بك هنا
API_KEY = "ضـع_مفتاح_API_الخاص_بـ_GEMINI_هنا"

if API_KEY == "ضـع_مفتاح_API_الخاص_بـ_GEMINI_هنا":
    st.error("❌ خطأ: يرجى وضع مفتاح الـ API لكي يعمل الموقع.")
    st.info("يمكنك الحصول عليه مجاناً من: https://aistudio.google.com/")
else:
    genai.configure(api_key=API_KEY)
    # اختيار النموذج الأحدث
    model = genai.GenerativeModel('gemini-1.5-flash')

    # 3. تصميم واجهة الموقع
    st.title("🛠️ محرك الحلول الهندسية الذكي")
    st.markdown("---")
    st.write("مرحباً بك زميلي المهندس. هذا الموقع مصمم لمساعدتك في حل أي مشكلة (برمجة، دوائر، ميكانيكا، أو حسابات معقدة).")

    # خانة إدخال المشكلة
    user_query = st.text_area(
        "صف المشكلة أو السؤال التقني بوضوح:",
        placeholder="مثلاً: كيف أبرمج حساس الموجات فوق الصوتية مع أردوينو وأعرض المسافة على شاشة LCD؟",
        height=150
    )

    # زر التشغيل
    if st.button("توليد الحل البرهاني والعملي ✨"):
        if user_query:
            with st.spinner('جاري تحليل المشكلة وابتكار الحل...'):
                try:
                    # صياغة الطلب ليكون الـ AI متخصصاً جداً
                    system_prompt = f"""
                    أنت خبير ميكاترونكس وذكاء اصطناعي برتبة بروفيسور. 
                    قم بحل المشكلة التالية لزميل طالب بكل دقة: {user_query}
                    يجب أن يحتوي ردك على:
                    - تحليل منطقي للمشكلة.
                    - الكود البرمجي الكامل (C++, Python, or MATLAB) مع شرح الأسطر.
                    - قائمة بالمكونات المطلوبة إذا كان مشروعاً هاردوير.
                    - نصيحة هندسية إضافية.
                    """
                    
                    response = model.generate_content(system_prompt)
                    
                    # عرض النتيجة
                    st.success("تم إيجاد الحل بنجاح!")
                    st.markdown("### 💡 الحل التفصيلي:")
                    st.markdown(response.text)
                    
                except Exception as e:
                    st.error(f"حدث خطأ فني: {e}")
        else:
            st.warning("الرجاء كتابة وصف للمشكلة أولاً.")

# 4. تذييل الصفحة للمشاركة
st.markdown("---")
st.caption("تطوير: منصة ميكاترونكس الذكية للطلاب | 2026")
